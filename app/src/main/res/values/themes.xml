<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Splash screen theme with dark background -->
    <style name="Theme.Panchangam100" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#8B0000</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_launcher_foreground</item>
        <item name="postSplashScreenTheme">@style/Theme.Panchangam100.Main</item>
    </style>

    <style name="Theme.Panchangam100.Main" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>
</resources>
